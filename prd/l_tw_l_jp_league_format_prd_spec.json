    },
    {
      "league_code": "L_JP",
      "display_name": "Japan League"
    }
  ],
  "core_format": {
    "teams": 8,
    "venue_model": "single venue",
    "season_model": "two splits per year",
    "splits": [
      "Spring",
      "Summer"
    ],
    "champions_per_year_per_league": 2,
    "regular_season_match_type": "Bo3",
    "playoff_match_type": "Bo5",
    "simultaneous_matches": false
  },
  "regular_season": {
    "format": "double round robin",
    "matches_per_team": 14,
    "total_matches_per_split": 56,
    "rounds_per_split": 14,
    "matches_per_round": 4,
    "duration_weeks": 7,
    "matches_per_week": 8,
    "preferred_weekly_distribution": [
      {
        "day": "Friday",
        "matches": 2,
        "match_type": "Bo3"
      },
      {
        "day": "Saturday",
        "matches": 3,
        "match_type": "Bo3"
      },
      {
        "day": "Sunday",
        "matches": 3,
        "match_type": "Bo3"
      }
    ],
    "weekend_priority": true,
    "weekend_matches_per_week": 6,
    "weekday_matches_per_week": 2,
    "team_scheduling_rule": "Each team should play exactly two matches per regular-season week and no more than one match on the same day.",
    "notes": [
      "The Friday/Saturday/Sunday pattern avoids putting all Bo3 matches on only two weekend days while keeping 75% of matches on Saturday/Sunday.",
      "Round labels may be split across multiple dates. The competition office should generate the actual team-by-team fixture list while preserving weekly totals and rest rules."
    ]
  },
  "playoffs": {
    "teams_qualified": 5,
    "format": "single-elimination stepladder tournament",
    "duration_weeks": 2,
    "all_matches": "Bo5",
    "daily_capacity": "one Bo5 match per day",
    "bracket_reset": false,
    "rounds": [
      {
        "round": 1,
        "default_day": "Saturday",
        "match": "Seed 4 vs Seed 5"
      },
      {
        "round": 2,
        "default_day": "Sunday",
        "match": "Seed 3 vs Round 1 Winner"
      },
      {
        "round": 3,
        "default_day": "Saturday",
        "match": "Seed 2 vs Round 2 Winner"
      },
      {
        "round": 4,
        "default_day": "Sunday",
        "match": "Seed 1 vs Round 3 Winner",
        "is_final": true
      }
    ]
  },
